# Default 5060 avoids macOS AirPlay (5000), common tools (5001), and stuck dev servers (5050).
PORT=5060
NODE_ENV=development
# false = MongoDB Atlas (or local/Docker). true = in-memory dev DB (data resets on restart).
USE_MEMORY_MONGO=false
# Atlas: replace <db_password> with your Database User password from MongoDB Atlas.
MONGO_URI=mongodb+srv://alexandrapetre36_db_user:<db_password>@cluster0.mvvrdru.mongodb.net/planit-meals?retryWrites=true&w=majority&appName=Cluster0
JWT_SECRET=replace_this_with_a_secure_secret
JWT_EXPIRES_IN=7d
CLIENT_ORIGIN=http://localhost:5173
